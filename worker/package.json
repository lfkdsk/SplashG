{
  "name": "splashg-data",
  "version": "0.1.0",
  "private": true,
  "description": "SplashG backend — Cloudflare Worker + D1 (users, repo bindings, follows)",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:init": "wrangler d1 execute splashg --remote --file=migrations/0001_init.sql",
    "db:init:local": "wrangler d1 execute splashg --local --file=migrations/0001_init.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251201.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.0.0"
  }
}
